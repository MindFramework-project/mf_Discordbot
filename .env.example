# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=""

# Client ID van je bot applicatie (voor deploy-commands.js)
CLIENT_ID=""

# Server IP en Port
SERVER_IP=""
SERVER_PORT=

# CFX.re join code (optioneel, anders wordt IP:Port gebruikt)
CFX_RE_CODE=""

# Optioneel: vast kanaal ID voor status embed (leeglaten voor /setup)
STATUS_CHANNEL_ID=""

# Interval in seconden voor status updates (standaard 30)
UPDATE_INTERVAL=31

# Staff rollen (komma-gescheiden ID's) — voor staff commands
STAFF_ROLES=""

# Owner role ID — voor /maintenance command
OWNER_ROLE_ID=""

# Pad naar txAdmin config.json (voor restart schedule)
TXADMIN_CONFIG_PATH=""

# Kanaal ID voor admin audit logs
STAFF_CHANNEL_ID=""

# Kanaal ID voor suggesties (via /suggest)
SUGGEST_CHANNEL_ID=""

# Voice channel ID voor live speler count
VOICE_CHANNEL_ID=""
